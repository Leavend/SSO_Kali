COMPOSE_PROJECT_NAME=sso-backend-prod

POSTGRES_IMAGE=postgres:17.2-alpine
REDIS_IMAGE=redis:7.4.2-alpine
SSO_IMAGE_PREFIX=ghcr.io/leavend/sso-kali
SSO_DEPLOY_TAG=main

APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=info
SSO_BACKEND_APP_KEY=base64:CHANGE_ME

SSO_BASE_URL=https://api-sso.timeh.my.id
SSO_ISSUER=https://api-sso.timeh.my.id
SSO_FRONTEND_URL=https://sso.timeh.my.id
SSO_LOGIN_URL=https://sso.timeh.my.id/login
SSO_RESOURCE_AUDIENCE=sso-resource-api
SSO_BACKEND_BIND=127.0.0.1:8200

POSTGRES_DB=sso_backend
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=CHANGE_ME
SSO_BACKEND_DB=sso_backend
SSO_BACKEND_DB_USER=postgres
SSO_BACKEND_DB_PASSWORD=CHANGE_ME

REDIS_PASSWORD=CHANGE_ME
REDIS_MAXMEMORY=192mb

SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=true
SSO_BACKEND_SESSION_COOKIE=__Host-broker_session
SSO_BACKEND_SESSION_DOMAIN=

OIDC_SIGNING_ALG=ES256
OIDC_SIGNING_KID=sso-main-key
OIDC_PRIVATE_KEY_PATH=/app/storage/app/oidc/private.pem
OIDC_PUBLIC_KEY_PATH=/app/storage/app/oidc/public.pem
OIDC_ACCESS_TOKEN_TTL=900
OIDC_ID_TOKEN_TTL=900
OIDC_REFRESH_TOKEN_TTL_DAYS=30
OIDC_REFRESH_TOKEN_FAMILY_TTL_DAYS=90
OIDC_AUTH_REQUEST_TTL=300
OIDC_AUTHORIZATION_CODE_TTL=60
OIDC_KEYS_DIR=./.secrets/oidc

ADMIN_PANEL_CLIENT_ID=sso-admin-panel
ADMIN_PANEL_ADMIN_EMAIL=admin@example.com
ADMIN_PANEL_SESSION_MANAGEMENT_ROLES=admin
ADMIN_PANEL_REQUIRE_MFA=false
ADMIN_PANEL_MFA_ACCEPTED_AMR=pwd

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true
OCTANE_GARBAGE_THRESHOLD_MB=50
OCTANE_MAX_EXECUTION_TIME=30
SSO_BACKEND_OCTANE_WORKERS=auto
SSO_BACKEND_OCTANE_MAX_REQUESTS=1000
SSO_BACKEND_WAIT_FOR_DB=false
SSO_BACKEND_PASSPORT_KEYS=false
SSO_BACKEND_EVENT_CACHE=true
SSO_BACKEND_FIX_PERMISSIONS=true

SSO_WORKER_QUEUE=default
SSO_WORKER_SLEEP=3
SSO_WORKER_TRIES=3
SSO_WORKER_BACKOFF=5
SSO_WORKER_TIMEOUT=60
SSO_WORKER_MAX_TIME=3600
SSO_WORKER_MEMORY=256

POSTGRES_MEM_LIMIT=1024m
POSTGRES_CPUS=1.00
REDIS_MEM_LIMIT=256m
REDIS_CPUS=0.25
SSO_BACKEND_MEM_LIMIT=768m
SSO_BACKEND_CPUS=0.75
SSO_WORKER_MEM_LIMIT=384m
SSO_WORKER_CPUS=0.35
