APP_NAME="SSO Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8200
TELESCOPE_ENABLED=true
TELESCOPE_DOMAIN=debug.dev-sso.timeh.my.id
TELESCOPE_ALLOWED_ENVIRONMENTS=local,dev
TELESCOPE_ALLOWED_IPS=
TELESCOPE_ALLOWED_HOSTS=debug.dev-sso.timeh.my.id
TELESCOPE_BASIC_AUTH_USER=
TELESCOPE_BASIC_AUTH_PASSWORD=
TELESCOPE_RECORD_ALL=true
TELESCOPE_PRUNE_HOURS=48
TELESCOPE_LOG_LEVEL=debug
TELESCOPE_QUERY_WATCHER_SLOW_MS=100
TELESCOPE_RESPONSE_SIZE_LIMIT=128

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sso_backend
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=__Host-laravel_session
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SSO_BACKEND_OCTANE_WORKERS=1
SSO_BACKEND_OCTANE_MAX_REQUESTS=500
SSO_BACKEND_QUEUE_SLEEP_SECONDS=5
SSO_BACKEND_QUEUE_MAX_JOBS=300
SSO_BACKEND_QUEUE_MAX_TIME=1800

CACHE_STORE=redis
# CACHE_PREFIX=sso-backend

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
SSO_ENGINE=native
SSO_BASE_URL=http://localhost:8200
SSO_FRONTEND_URL=http://localhost:3000
SSO_CORS_ALLOWED_ORIGINS=http://localhost:3000
SSO_ISSUER=http://localhost:8200
SSO_RESOURCE_AUDIENCE=sso-resource-api
OIDC_UPSTREAM_PUBLIC_ISSUER=http://localhost:8200
OIDC_UPSTREAM_INTERNAL_ISSUER=http://localhost:8200
OIDC_UPSTREAM_CLIENT_ID=prototype-upstream-client
OIDC_UPSTREAM_CLIENT_SECRET=prototype-upstream-secret
OIDC_UPSTREAM_REDIRECT_URI=http://localhost:8200/callbacks/upstream
OIDC_UPSTREAM_SCOPE="openid profile email offline_access"
OIDC_SIGNING_ALG=ES256
OIDC_SIGNING_KID=prototype-key-1
OIDC_AUTH_REQUEST_TTL=900
OIDC_AUTH_REQUEST_FALLBACK_TTL=1800
OIDC_AUTHORIZATION_CODE_TTL=120
OIDC_PUBLIC_METADATA_CACHE_TTL_SECONDS=300
OIDC_PUBLIC_METADATA_STALE_WHILE_REVALIDATE_SECONDS=60
# Dedicated 256-bit key for encrypting upstream refresh tokens.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# If unset, falls back to an APP_KEY derivation (NOT recommended for production).
UPSTREAM_TOKEN_KEY=
OIDC_AUTHORIZE_RATE_LIMIT_PER_MINUTE=20
OIDC_CALLBACK_RATE_LIMIT_PER_MINUTE=30
OIDC_ACCESS_TOKEN_TTL=15
OIDC_ID_TOKEN_TTL=15
OIDC_REFRESH_TOKEN_TTL_DAYS=30
OIDC_CLIENT_SECRET_HASH_MEMORY_KIB=19456
OIDC_CLIENT_SECRET_HASH_TIME_COST=3
OIDC_CLIENT_SECRET_HASH_THREADS=1
APP_A_CLIENT_ID=prototype-app-a
APP_A_REDIRECT_URI=http://localhost:3001/auth/callback
APP_A_POST_LOGOUT_REDIRECT_URI=http://localhost:3001
APP_A_BACKCHANNEL_LOGOUT_URI=http://localhost:3001/api/backchannel/logout
APP_B_CLIENT_ID=prototype-app-b
APP_B_CLIENT_SECRET_HASH=$argon2id$v=19$m=19456,t=3,p=1$LjdEd3dSZERUcjdtcGJhTA$69AablhTFZNWAg7DFVgO7aok3D9GXKESsp2iCnpwpsg
APP_B_REDIRECT_URI=http://localhost:8300/auth/callback
APP_B_POST_LOGOUT_REDIRECT_URI=http://localhost:8300
APP_B_BACKCHANNEL_LOGOUT_URI=http://localhost:8300/auth/backchannel/logout
ADMIN_PANEL_SESSION_MANAGEMENT_ROLES=admin
ADMIN_PANEL_REQUIRE_MFA=false
ADMIN_PANEL_MFA_ACCEPTED_AMR=mfa,otp,u2f
ADMIN_PANEL_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=20
ADMIN_PANEL_READ_RATE_LIMIT_PER_MINUTE=60
ADMIN_PANEL_WRITE_RATE_LIMIT_PER_MINUTE=10
