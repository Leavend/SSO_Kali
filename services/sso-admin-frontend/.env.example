VITE_ADMIN_BASE_URL=http://localhost:8080
VITE_SSO_BASE_URL=http://localhost:8200
# Account-widget base. Leave UNSET for the same-origin default: the admin BFF
# proxies /widget/* to the backend and holds the first-party __Host-sso_session
# cookie on the admin origin. Set this only to point the widget bar at a
# cross-origin front-door host (the superseded WACC1 cross-origin wiring).
# VITE_SSO_WIDGET_BASE_URL=
ADMIN_OIDC_CLIENT_ID=sso-admin-panel
ADMIN_OIDC_CLIENT_SECRET=replace-with-64-random-characters
SSO_INTERNAL_BASE_URL=http://localhost:8200
SSO_INTERNAL_TOKEN_URL=http://localhost:8200/token
SSO_INTERNAL_JWKS_URL=http://localhost:8200/jwks
SESSION_ENCRYPTION_SECRET=replace-with-at-least-32-characters
# --- Nuxt/Nitro server runtimeConfig (server-only; never exposed to the browser) ---
ADMIN_OIDC_ISSUER=http://localhost:8200
ADMIN_OIDC_PUBLIC_ISSUER=http://localhost:8200
SSO_ADMIN_SESSION_REDIS_URL=redis://localhost:6379
SSO_SESSION_IDLE_TTL_SECONDS=1800
SSO_SESSION_ABSOLUTE_TTL_SECONDS=43200
SSO_FRESH_AUTH_TTL_SECONDS=300
# Public (safe to expose): app base URL only
ADMIN_APP_BASE_URL=http://localhost:3000
