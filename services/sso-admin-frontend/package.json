{
  "name": "sso-admin-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node dist/server/server/index.js",
    "build": "run-s type-check build:web build:server",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "build:web": "vite build",
    "build:server": "tsc --build tsconfig.server.json --force",
    "start": "node dist/server/server/index.js",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json && vue-tsc --noEmit -p tsconfig.vitest.json && tsc -p tsconfig.server.json --noEmit --tsBuildInfoFile ./node_modules/.tmp/tsconfig.server.noemit.tsbuildinfo",
    "typecheck": "npm run type-check",
    "test": "npm run test:unit -- --run",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "eslint \"src/**/*.vue\" --cache",
    "format": "prettier --write --experimental-cli .",
    "format:check": "prettier --check --experimental-cli ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "redis": "^6.0.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.71.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.71.0",
    "prettier": "3.9.1",
    "typescript": "~6.0.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
