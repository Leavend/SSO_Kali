{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/web/*"],
      "@shared/*": ["./src/shared/*"],
      "@parent-ui/*": ["../../packages/dev-sso-parent-ui/*"]
    }
  },
  "include": ["src/web/**/*.ts", "src/web/**/*.vue", "src/shared/**/*.ts"]
}
