{
	"name": "sso-frontend",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 0.0.0.0 --port 5173",
		"dev:server": "tsx src/server/index.ts",
		"build": "run-s typecheck build:web build:server",
		"build:web": "vite build",
		"build:server": "tsc --build tsconfig.server.json --force",
		"start": "node dist/server/server/index.js",
		"lint": "run-s lint:filenames lint:eslint security:broker security:storage wcag:theme",
		"lint:filenames": "node scripts/check-source-filenames.mjs",
		"lint:eslint": "eslint src eslint.config.ts vite.config.ts vitest.config.ts",
		"security:broker": "node ../../tools/frontend-security/check-broker-boundary.mjs .",
		"security:storage": "node ../../tools/frontend-security/check-browser-storage-policy.mjs .",
		"wcag:theme": "node scripts/check-wcag-theme.mjs",
		"typecheck": "run-p typecheck:web typecheck:server",
		"typecheck:web": "vue-tsc --build tsconfig.app.json",
		"typecheck:server": "tsc -p tsconfig.server.json --noEmit --tsBuildInfoFile ./node_modules/.tmp/tsconfig.server.noemit.tsbuildinfo",
		"test": "vitest run",
		"smoke": "node scripts/smoke-built-server.mjs",
		"preview": "vite preview --host 0.0.0.0 --port 4173"
	},
	"dependencies": {
		"@vueuse/core": "^14.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jose": "^6.2.3",
		"lucide-vue-next": "^1.0.0",
		"pinia": "^3.0.4",
		"qrcode-generator": "^2.0.4",
		"redis": "^5.10.0",
		"reka-ui": "^2.10.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"vue": "^3.5.39",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@emnapi/core": "^1.11.1",
		"@emnapi/runtime": "^1.11.1",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/vite": "^4.3.1",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^24.12.2",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/eslint-plugin": "^1.6.20",
		"@vue/eslint-config-typescript": "^14.9.0",
		"@vue/test-utils": "^2.4.11",
		"@vue/tsconfig": "^0.9.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-oxlint": "~1.71.0",
		"eslint-plugin-vue": "~10.9.2",
		"jiti": "^2.6.1",
		"jsdom": "^29.1.1",
		"npm-run-all2": "^8.0.4",
		"oxlint": "~1.71.0",
		"prettier": "3.8.4",
		"tsx": "^4.22.4",
		"typescript": "~6.0.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.5",
		"vue-tsc": "^3.3.5"
	}
}
