COMPOSE_PROJECT_NAME=sso-prototype-dev

TRAEFIK_IMAGE=traefik:v3.6.8
POSTGRES_IMAGE=postgres:17.2-alpine
REDIS_IMAGE=redis:7.4.2-alpine
ZITADEL_VERSION=v4.14.0

PROXY_HTTP_BIND_IP=127.0.0.1
PROXY_HTTP_PUBLISHED_PORT=18080

SSO_DOMAIN=dev-sso.timeh.my.id
DEBUG_SSO_DOMAIN=debug.dev-sso.timeh.my.id
ZITADEL_DOMAIN=id.dev-sso.timeh.my.id
APP_A_DOMAIN=app-a.timeh.my.id
APP_B_DOMAIN=app-b.timeh.my.id
ZITADEL_EXTERNALPORT=443
ZITADEL_EXTERNALSECURE=true
ZITADEL_PUBLIC_SCHEME=https
ZITADEL_MASTERKEY=REPLACE_WITH_32_CHAR_MASTERKEY
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z
ZITADEL_FIRSTINSTANCE_MACHINEKEYPATH=/zitadel/bootstrap/admin-machinekey.json
ZITADEL_FIRSTINSTANCE_PATPATH=/zitadel/bootstrap/admin.pat
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_USERNAME=prototype-admin
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_NAME=Prototype SSO Admin
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINEKEY_EXPIRATIONDATE=2099-01-01T00:00:00Z
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINEKEY_TYPE=1
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_PAT_EXPIRATIONDATE=2099-01-01T00:00:00Z

POSTGRES_DB=zitadel
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
SSO_BACKEND_DB=sso_backend
APP_B_DB=app_b

REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
ZITADEL_DATABASE_POSTGRES_DSN=postgresql://postgres:${POSTGRES_ADMIN_PASSWORD}@postgres:5432/zitadel?sslmode=disable
ZITADEL_CACHES_CONNECTORS_REDIS_ENABLED=false
ZITADEL_CACHES_CONNECTORS_REDIS_URL=
ZITADEL_CACHES_CONNECTORS_REDIS_NETWORK=tcp
ZITADEL_CACHES_CONNECTORS_REDIS_ADDR=redis:6379
ZITADEL_CACHES_CONNECTORS_REDIS_USERNAME=default
ZITADEL_CACHES_INSTANCE_CONNECTOR=postgres
ZITADEL_CACHES_MILESTONES_CONNECTOR=postgres
ZITADEL_CACHES_ORGANIZATION_CONNECTOR=postgres

TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_ACCESSLOG_ENABLED=true
ZITADEL_ACCESS_LOG_STDOUT_ENABLED=true
LOGIN_OTEL_SERVICE_NAME=zitadel-login
LOGIN_OTEL_EXPORTER_OTLP_ENDPOINT=
LOGIN_OTEL_EXPORTER_OTLP_PROTOCOL=grpc
ZITADEL_LOGIN_ACTIVE_BASE_PATH=/ui/v2/login
ZITADEL_LOGIN_HOSTED_BASE_PATH=/ui/v2/login
ZITADEL_LOGIN_VUE_BASE_PATH=/ui/v2/login-vue
ZITADEL_LOGIN_VUE_COOKIE_SECRET=REPLACE_WITH_AT_LEAST_32_CHARACTER_LOGIN_VUE_SECRET
ZITADEL_LOGIN_REQUIRE_TOTP_AFTER_PASSWORD=true

APP_ENV=dev
APP_DEBUG=true
LOG_LEVEL=info
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
TELESCOPE_ENABLED=true
TELESCOPE_DOMAIN=${DEBUG_SSO_DOMAIN}
TELESCOPE_ALLOWED_ENVIRONMENTS=dev
TELESCOPE_ALLOWED_IPS=
TELESCOPE_ALLOWED_HOSTS=${DEBUG_SSO_DOMAIN}
TELESCOPE_BASIC_AUTH_USER=debug
TELESCOPE_BASIC_AUTH_PASSWORD=REPLACE_WITH_STRONG_TELESCOPE_PASSWORD
TELESCOPE_RECORD_ALL=true
TELESCOPE_PRUNE_HOURS=48
TELESCOPE_LOG_LEVEL=debug
TELESCOPE_QUERY_WATCHER_SLOW_MS=100
TELESCOPE_RESPONSE_SIZE_LIMIT=128

SSO_BACKEND_APP_KEY=base64:REPLACE_WITH_SSO_BACKEND_APP_KEY
APP_B_APP_KEY=base64:REPLACE_WITH_APP_B_APP_KEY

OIDC_SIGNING_ALG=ES256
OIDC_SIGNING_KID=dev-sso-key-1
OIDC_PRIVATE_KEY_PATH=/app/storage/app/oidc/private.pem
OIDC_PUBLIC_KEY_PATH=/app/storage/app/oidc/public.pem
OIDC_ACCESS_TOKEN_TTL=15
OIDC_ID_TOKEN_TTL=15
OIDC_REFRESH_TOKEN_TTL_DAYS=30
OIDC_CLIENT_SECRET_HASH_MEMORY_KIB=65536
OIDC_CLIENT_SECRET_HASH_TIME_COST=4
OIDC_CLIENT_SECRET_HASH_THREADS=2
OIDC_AUTH_REQUEST_TTL=900
OIDC_AUTH_REQUEST_FALLBACK_TTL=1800
OIDC_AUTHORIZATION_CODE_TTL=120
OIDC_AUTHORIZE_RATE_LIMIT_PER_MINUTE=20
OIDC_CALLBACK_RATE_LIMIT_PER_MINUTE=30

SSO_BASE_URL=https://dev-sso.timeh.my.id
SSO_ISSUER=https://dev-sso.timeh.my.id
SSO_INTERNAL_BASE_URL=http://sso-backend:8000
SSO_RESOURCE_AUDIENCE=sso-resource-api
SSO_BACKEND_SESSION_COOKIE=__Host-broker_session
SSO_FRONTEND_BASE_PATH=/portal
SSO_ADMIN_VUE_BASE_PATH=/__vue-preview

ZITADEL_ISSUER=https://id.dev-sso.timeh.my.id
ZITADEL_BROKER_PUBLIC_ISSUER=https://id.dev-sso.timeh.my.id
ZITADEL_BROKER_INTERNAL_ISSUER=http://zitadel-api:8080
ZITADEL_BROKER_CLIENT_ID=REPLACE_AFTER_ZITADEL_BOOTSTRAP
ZITADEL_BROKER_CLIENT_SECRET=REPLACE_AFTER_ZITADEL_BOOTSTRAP
ZITADEL_BROKER_REDIRECT_URI=https://dev-sso.timeh.my.id/callbacks/zitadel
ZITADEL_BROKER_SCOPE=openid profile email offline_access
ZITADEL_PROTOTYPE_PROJECT_NAME=Prototype SSO Dev
ZITADEL_BROKER_APP_NAME=Prototype SSO Broker

SSO_FRONTEND_PORT=3000
SSO_BACKEND_PORT=8200
APP_A_PORT=3001
APP_B_PORT=8300

APP_A_BASE_URL=https://app-a.timeh.my.id
APP_A_CLIENT_ID=prototype-app-a
APP_A_REDIRECT_URI=https://app-a.timeh.my.id/auth/callback
APP_A_POST_LOGOUT_REDIRECT_URI=https://app-a.timeh.my.id
APP_A_BACKCHANNEL_LOGOUT_URI=http://app-a-next:3000/api/backchannel/logout
APP_A_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
APP_A_SESSION_COOKIE_NAME=__Host-app-a-session
APP_A_SESSION_IDLE_TTL_SECONDS=604800
APP_A_SESSION_ABSOLUTE_TTL_SECONDS=2592000
APP_A_REFRESH_LOCK_TTL_SECONDS=15

APP_B_BASE_URL=https://app-b.timeh.my.id
APP_B_CLIENT_ID=prototype-app-b
APP_B_CLIENT_SECRET=REPLACE_WITH_APP_B_CLIENT_SECRET_PLAINTEXT
APP_B_CLIENT_SECRET_HASH=REPLACE_WITH_ARGON2ID_HASH_FOR_APP_B_CLIENT_SECRET
APP_B_REDIRECT_URI=https://app-b.timeh.my.id/auth/callback
APP_B_POST_LOGOUT_REDIRECT_URI=https://app-b.timeh.my.id
APP_B_BACKCHANNEL_LOGOUT_URI=http://app-b-laravel:8000/auth/backchannel/logout
APP_B_SESSION_DOMAIN=app-b.timeh.my.id
ADMIN_PANEL_BASE_URL=https://dev-sso.timeh.my.id
ADMIN_PANEL_CLIENT_ID=sso-admin-panel
ADMIN_PANEL_REDIRECT_URI=https://dev-sso.timeh.my.id/auth/callback
ADMIN_PANEL_POST_LOGOUT_REDIRECT_URI=https://dev-sso.timeh.my.id
ADMIN_PANEL_BACKCHANNEL_LOGOUT_URI=http://sso-backend:8000/connect/backchannel/admin-panel/logout
ADMIN_PANEL_ADMIN_EMAIL=admin@example.com
ADMIN_PANEL_SESSION_SECRET=REPLACE_WITH_AT_LEAST_32_CHARACTER_ADMIN_PANEL_SECRET
ADMIN_PANEL_SESSION_MANAGEMENT_ROLES=admin
ADMIN_PANEL_REQUIRE_MFA=false
ADMIN_PANEL_MFA_ACCEPTED_AMR=mfa,otp,u2f
ADMIN_PANEL_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=20
ADMIN_PANEL_READ_RATE_LIMIT_PER_MINUTE=60
ADMIN_PANEL_WRITE_RATE_LIMIT_PER_MINUTE=10
SSO_FRONTEND_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/6

RESOURCE_API_BASE_URL=http://sso-backend:8000
